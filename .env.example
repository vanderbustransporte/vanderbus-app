# Copiar a `.env` y completar. El `.env` NO se versiona.
#
# Ambas variables son públicas por diseño: Vite las inyecta en el bundle que se
# descarga el navegador. Estar en `.env` no las vuelve secretas — sirve para
# poder rotarlas sin tocar código y para no publicar la URL del proyecto en el
# repo. La barrera de seguridad real es RLS, no la anon key.
#
# NUNCA poner acá la service_role key: esa sí es secreta y solo vive en las
# Edge Functions (que corren en los servidores de Supabase).

VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon key del proyecto>

# --- Solo para desarrollo local: no los usa la app, los usan los scripts de
# --- supabase/checks/ y la verificacion manual en el navegador.

# Superadmin (ademas owner del org Vanderbus)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Usuario de prueba de una segunda org, para la suite de aislamiento RLS
# (supabase/checks/aislamiento_rls.mjs)
TEST_ORG_B_EMAIL=
TEST_ORG_B_PASSWORD=

# Usuario staff de esa segunda org, para permisos_seccion_check.mjs
TEST_ORG_B_STAFF_EMAIL=
TEST_ORG_B_STAFF_PASSWORD=

# Secret del cron GPS (vault de Supabase: gps_cron_secret), para gps_ingesta_check.mjs
CRON_SECRET=
