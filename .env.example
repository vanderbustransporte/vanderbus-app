# Copiar a `.env` y completar. El `.env` NO se versiona.
#
# Ambas variables son públicas por diseño: Vite las inyecta en el bundle que se
# descarga el navegador. Estar en `.env` no las vuelve secretas — sirve para
# poder rotarlas sin tocar código y para no publicar la URL del proyecto en el
# repo. La barrera de seguridad real es RLS, no la anon key.
#
# NUNCA poner acá la service_role key: esa sí es secreta y solo vive en las
# Edge Functions (que corren en los servidores de Supabase).

VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon key del proyecto>
